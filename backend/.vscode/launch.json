{
    "version": "0.2.0",
    "configurations": [
        {
            "type": "node",
            "request": "launch",
            "name": "Debug Skill Tracker",
            "skipFiles": ["<node_internals>/**"],
            "program": "${workspaceFolder}/backend/server.js",
            "cwd": "${workspaceFolder}", 
            "runtimeExecutable": "nodemon",
            "envFile": "${workspaceFolder}/.env",
            "restart": true,
            "console": "integratedTerminal"
        }
    ]
}